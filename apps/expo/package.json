{
  "name": "@led-panel/expo",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "build:android:debug": "JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home cd android && ./gradlew assembleDebug",
    "build:android:release": "JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home ANDROID_HOME=$HOME/Library/Android/sdk ./gradlew bundleRelease",
    "build:android:bundle:debug": "cd android && JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home ANDROID_HOME=$HOME/Library/Android/sdk ./gradlew bundleDebug",
    "build:ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6",
    "@led-panel/core": "workspace:*",
    "@react-native-community/slider": "^4.5.5",
    "@shopify/react-native-skia": "^1.5.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-camera": "~16.0.0",
    "expo-constants": "~17.0.8",
    "expo-keep-awake": "~14.0.3",
    "expo-linking": "~7.0.5",
    "expo-navigation-bar": "~4.0.9",
    "expo-router": "~4.0.0",
    "expo-screen-orientation": "~8.0.0",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.0",
    "react": "~18.3.1",
    "react-native": "~0.76.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-qrcode-svg": "^6.3.0",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "^15.8.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@types/react": "~18.3.0",
    "babel-preset-expo": "~12.0.0",
    "typescript": "^5.7.0"
  }
}
